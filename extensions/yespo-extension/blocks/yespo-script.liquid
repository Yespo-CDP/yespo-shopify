{%- assign yespo_script = shop.metafields['$app'].yespo-script -%}
{%- assign yespo_web_push_script = shop.metafields['$app'].yespo-web-push-script -%}
{%- assign yespo_web_tracking_enabled = shop.metafields['$app'].web-tracking-enabled.value -%}
{%- assign yespo_app_host = shop.metafields['$app'].yespo-app-host -%}

<script>
    function yespoAppAuthCallback () {
       console.log('------YESPO AUTH CALLBACK------');

       const host = {{ yespo_app_host | json }};
       const customer = {% if customer %}
        {
          id: {{ customer.id | json }},
          email: {{ customer.email | json }},
          firstName: {{ customer.first_name | json }},
          lastName: {{ customer.last_name | json }},
          phone: {{ customer.phone | json }}
         }
        {% else %}
          null
          {% endif %};
       const shop = {{ shop.domain | json }};
       console.log('Yespo callback customer', customer)
       console.log('Yespo callback host', host)
       console.log('Yespo callback shop', shop)

      return new Promise((resolve, reject) => {
        try {
          if (!customer) {
            reject('No customer.');
          }

           if (!shop) {
              reject('No shop.');
           }

           const payload = {
             externalCustomerId: customer.id,
             email: customer.email ,
             phone: customer.phone,
             shop: shop
           };

           console.log('Yespo get auth token payload', payload)

           fetch(`${host}/public/app-inbox/get-token`, {
              method: "POST",
              body: JSON.stringify(payload)
            })
            .then(res => {
              if (!res.ok) {
                return res.text().then(text => reject(`HTTP ${res.status}: ${text}`));
              }
              return res.json();
            })
            .then(data => {
              console.log('Yespo contact auth token', data.token)
              resolve(data.token || '')
            })
            .catch(err => reject(err));
        } catch (e) {
          console.error("[YespoAppAuthCallback] Exception:", e);
          return;
        }
      })
    }
</script>

<script>
    function yespoGetCurrentLanguage () {
       return {{ localization.language.iso_code | json }} || navigator.language || 'en';
    }
</script>

{% if yespo_script != blank %}
  {{ yespo_script }}
{% endif %}

{% if yespo_web_push_script != blank %}
  {{ yespo_web_push_script }}
{% endif %}

{% assign current_variant = product.selected_or_first_available_variant %}


<script id="yespo_data" type="application/json">
  {
    "host": {{ yespo_app_host | json }},
    "pageTemplate": {{ template.name | json }},
    "domain":  {{ shop.domain | json }},
    "product": {{ product | json }},
    "currentVariant": {{ current_variant | json }},
    "language": "{{ localization.language.iso_code }}",
    "collection":
      {% if collection %}
        {
          "id": {{ collection.id | json }},
          "title": {{ collection.title | json }},
          "handle": {{ collection.handle | json }},
          "categoryTypeMapping": {% if collection.metafields['$app'].yespo_category_type %}{{ collection.metafields['$app'].yespo_category_type }}{% else %}null{% endif %}
        }
      {% else %}
        null
      {% endif %},
    "customer":
      {% if customer %}
        {
          "id": {{ customer.id | json }},
          "email": {{ customer.email | json }},
          "firstName": {{ customer.first_name | json }},
          "lastName": {{ customer.last_name | json }},
          "phone": {{ customer.phone | json }}
        }
      {% else %}
        null
      {% endif %}
  }
</script>



{% if yespo_web_tracking_enabled == true %}
  <script>
    console.log('ENABLED')
  </script>
  <script src="{{ "web-tracking.js" | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Yespo script",
  "target": "head",
}
{% endschema %}

